{
  "name": "@webrobot/frontend-sdk",
  "version": "1.0.0",
  "description": "TypeScript SDK per integrazione WebRobot Agentic System con Next.js",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*",
    "src/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts src/**/*.tsx",
    "lint:fix": "eslint src/**/*.ts src/**/*.tsx --fix",
    "prepack": "npm run build"
  },
  "keywords": [
    "webrobot",
    "agentic",
    "crewai",
    "rag",
    "etl",
    "typescript",
    "react",
    "nextjs",
    "sdk",
    "chatbot",
    "ai",
    "automation"
  ],
  "author": "WebRobot Team <team@webrobot.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/WebRobot-Ltd/webrobot-frontend-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/WebRobot-Ltd/webrobot-frontend-sdk/issues"
  },
  "homepage": "https://github.com/WebRobot-Ltd/webrobot-frontend-sdk#readme",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.45.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jest": "^29.6.0",
    "typescript": "^5.1.0"
  },
  "dependencies": {
    "prometheus-client": "^0.0.1"
  }
}
